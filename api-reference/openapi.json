              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetWalletBalanceOutput"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "No data available"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/wallet/{wallet_id}/status": {
      "get": {
        "tags": [
          "Wallet"
        ],
        "operationId": "get_wallet_status",
        "parameters": [
          {
            "name": "wallet_id",
            "in": "path",
            "description": "Transcorp wallet id (`transcorp_wallet_id` from GET /wallet)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status from DB",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetWalletStatusOutput"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "No data available"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/wallet/{wallet_id}/transactions/history/{number_of_days}": {
      "get": {
        "tags": [
          "Wallet"
        ],
        "operationId": "get_wallet_transaction_history",
        "parameters": [
          {
            "name": "wallet_id",
            "in": "path",
            "description": "Transcorp wallet id (`transcorp_wallet_id` from GET /wallet)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "number_of_days",
            "in": "path",
            "description": "Filter window in days (0 = all history, 1–365)",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Local ledger (max 10 entries)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetWalletTransactionHistoryOutput"
                }
              }
            }
          },
          "400": {
            "description": "number_of_days out of range"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "No data available"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
