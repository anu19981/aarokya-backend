{
  "openapi": "3.1.0",
  "info": {
    "title": "Aarokya API",
    "description": "API for the Aarokya users module — platform management, user lifecycle, and token issuance.",
    "contact": {
      "name": "Aarokya Engineering"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local"
    },
    {
      "url": "https://sandbox.api.aarokya.in",
      "description": "Sandbox"
    },
    {
      "url": "https://api.aarokya.in",
      "description": "Production"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "text/plain": {
                "schema": { "type": "string", "example": "OK" }
              }
            }
          }
        }
      }
    },
    "/auth/token": {
      "post": {
        "tags": ["Auth"],
        "summary": "Generate token",
        "description": "Authenticate a user by phone number and platform, returning a JWT access token. Creates the user account on first call (find-or-create). Requires an external partner API key (`api-key` header).",
        "operationId": "generate_token",
        "security": [{ "ExternalApiKey": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenerateTokenRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Token issued",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenerateTokenResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/platforms": {
      "post": {
        "tags": ["Platforms"],
        "summary": "Create platform",
        "description": "Create a new platform (tenant). Requires admin API key.",
        "operationId": "create_platform",
        "security": [{ "AdminApiKey": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePlatformRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Platform created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlatformResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "get": {
        "tags": ["Platforms"],
        "summary": "List platforms",
        "description": "Returns a paginated list of platforms. Requires admin API key.",
        "operationId": "list_platforms",
        "security": [{ "AdminApiKey": [] }],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": { "$ref": "#/components/schemas/PlatformStatus" }
          },
          {
            "name": "start_time",
            "in": "query",
            "schema": { "type": "string", "format": "date-time", "example": "2024-01-01T00:00:00Z" }
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": { "type": "string", "format": "date-time", "example": "2024-12-31T23:59:59Z" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of platforms",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlatformListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/platforms/{platform_id}": {
      "get": {
        "tags": ["Platforms"],
        "summary": "Get platform",
        "description": "Fetch a platform by ID. Requires admin API key.",
        "operationId": "get_platform_by_id",
        "security": [{ "AdminApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/platform_id" }
        ],
        "responses": {
          "200": {
            "description": "Platform found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlatformResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "patch": {
        "tags": ["Platforms"],
        "summary": "Update platform",
        "description": "Update a platform's name. Requires admin API key.",
        "operationId": "update_platform",
        "security": [{ "AdminApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/platform_id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdatePlatformRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Platform updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlatformResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "delete": {
        "tags": ["Platforms"],
        "summary": "Delete platform",
        "description": "Soft-delete a platform (sets status to inactive). Requires admin API key.",
        "operationId": "delete_platform",
        "security": [{ "AdminApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/platform_id" }
        ],
        "responses": {
          "200": {
            "description": "Platform deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeletePlatformResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "List users",
        "description": "Returns a paginated list of users. Requires admin API key.",
        "operationId": "list_users",
        "security": [{ "AdminApiKey": [] }],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": { "$ref": "#/components/schemas/UserStatus" }
          },
          {
            "name": "start_time",
            "in": "query",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/users/{user_id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get user",
        "description": "Fetch a user by ID. JWT-authenticated users can only fetch their own record; admin key has full access.",
        "operationId": "get_user_by_id",
        "security": [{ "BearerAuth": [] }, { "AdminApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/user_id" }
        ],
        "responses": {
          "200": {
            "description": "User found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "patch": {
        "tags": ["Users"],
        "summary": "Update user",
        "description": "Update a user's profile fields. Allowed for users in both `onboarding` and `active` status.",
        "operationId": "update_user",
        "security": [{ "BearerAuth": [] }, { "AdminApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/user_id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateUserRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete user",
        "description": "Soft-delete a user. Requires admin API key.",
        "operationId": "delete_user",
        "security": [{ "AdminApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/user_id" }
        ],
        "responses": {
          "200": {
            "description": "User deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteUserResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/users/{user_id}/complete_onboarding": {
      "post": {
        "tags": ["Users"],
        "summary": "Complete onboarding",
        "description": "Finalise a user's onboarding by submitting required profile fields. Transitions `status` from `onboarding` → `active` and returns a fresh access token.",
        "operationId": "complete_onboarding",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/user_id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompleteOnboardingRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Onboarding complete",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CompleteOnboardingResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "AdminApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "admin-api-key",
        "description": "Internal admin key. Used for platform management and admin-level user operations."
      },
      "ExternalApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "api-key",
        "description": "External partner key (e.g. Namma Yatri). Used to issue tokens on behalf of users."
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT issued by `POST /auth/token`. Pass as `Authorization: Bearer <token>`."
      }
    },
    "parameters": {
      "platform_id": {
        "name": "platform_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "example": "platform_3Xk9mNpQrBvLwJtY2c"
      },
      "user_id": {
        "name": "user_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "example": "usr_7Hq4nMdKpRsXwYzA1b"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request body or parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "error": { "code": "VALIDATION_ERROR", "message": "name cannot be empty" } }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid authentication",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "error": { "code": "UNAUTHORIZED", "message": "missing or invalid API key" } }
          }
        }
      },
      "Forbidden": {
        "description": "Authenticated but not authorised for this resource",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "error": { "code": "FORBIDDEN", "message": "access to this user is not allowed" } }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "error": { "code": "NOT_FOUND", "message": "platform not found" } }
          }
        }
      },
      "Conflict": {
        "description": "Resource already exists",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "error": { "code": "CONFLICT", "message": "a platform with this name already exists" } }
          }
        }
      },
      "InternalError": {
        "description": "Unexpected server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      },
      "PlatformStatus": {
        "type": "string",
        "enum": ["active", "inactive"],
        "description": "Platform lifecycle status."
      },
      "UserStatus": {
        "type": "string",
        "enum": ["onboarding", "active", "deactivated"],
        "description": "User lifecycle status."
      },
      "Gender": {
        "type": "string",
        "enum": ["male", "female", "other"]
      },
      "IdProofType": {
        "type": "string",
        "enum": ["aadhaar", "pan", "passport", "driving_license", "voter_id"]
      },
      "AddressDetails": {
        "type": "object",
        "properties": {
          "line1": { "type": "string", "example": "42 MG Road" },
          "line2": { "type": "string", "example": "Koramangala" },
          "city": { "type": "string", "example": "Bengaluru" },
          "state": { "type": "string", "example": "Karnataka" },
          "pincode": { "type": "string", "example": "560034" },
          "country": { "type": "string", "example": "IN" }
        }
      },
      "IdProof": {
        "type": "object",
        "required": ["proof_type", "number"],
        "properties": {
          "proof_type": { "$ref": "#/components/schemas/IdProofType" },
          "number": { "type": "string", "description": "Document number (masked in logs)." }
        }
      },
      "GenerateTokenRequest": {
        "type": "object",
        "required": ["phone_number", "phone_country_code", "platform_id"],
        "properties": {
          "phone_number": { "type": "string", "example": "9876543210", "description": "Masked in server logs." },
          "phone_country_code": { "type": "string", "example": "+91" },
          "platform_id": { "type": "string", "example": "platform_3Xk9mNpQrBvLwJtY2c" }
        }
      },
      "GenerateTokenResponse": {
        "type": "object",
        "required": ["access_token"],
        "properties": {
          "access_token": { "type": "string", "description": "JWT. Pass as `Authorization: Bearer <token>`." }
        }
      },
      "CreatePlatformRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "Namma Yatri" }
        }
      },
      "UpdatePlatformRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "Namma Yatri v2" }
        }
      },
      "PlatformResponse": {
        "type": "object",
        "required": ["id", "name", "status", "created_at", "last_modified_at"],
        "properties": {
          "id": { "type": "string", "example": "platform_3Xk9mNpQrBvLwJtY2c" },
          "name": { "type": "string", "example": "Namma Yatri" },
          "status": { "$ref": "#/components/schemas/PlatformStatus" },
          "created_at": { "type": "string", "format": "date-time", "example": "2024-06-01T10:30:00Z" },
          "last_modified_at": { "type": "string", "format": "date-time", "example": "2024-06-01T10:30:00Z" }
        }
      },
      "PlatformListResponse": {
        "type": "object",
        "required": ["data", "total", "limit", "offset"],
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PlatformResponse" }
          },
          "total": { "type": "integer", "example": 5 },
          "limit": { "type": "integer", "example": 20 },
          "offset": { "type": "integer", "example": 0 }
        }
      },
      "DeletePlatformResponse": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string", "example": "platform_3Xk9mNpQrBvLwJtY2c" },
          "status": { "$ref": "#/components/schemas/PlatformStatus" }
        }
      },
      "UserResponse": {
        "type": "object",
        "required": ["user_id", "phone_number", "phone_country_code", "status"],
        "properties": {
          "user_id": { "type": "string", "example": "usr_7Hq4nMdKpRsXwYzA1b" },
          "phone_number": { "type": "string", "example": "9876543210" },
          "phone_country_code": { "type": "string", "example": "+91" },
          "first_name": { "type": "string", "example": "Ravi" },
          "last_name": { "type": "string", "example": "Kumar" },
          "email": { "type": "string", "example": "ravi@example.com" },
          "dob": { "type": "string", "format": "date", "example": "1990-05-15" },
          "gender": { "$ref": "#/components/schemas/Gender" },
          "address": { "$ref": "#/components/schemas/AddressDetails" },
          "status": { "$ref": "#/components/schemas/UserStatus" }
        }
      },
      "UserListResponse": {
        "type": "object",
        "required": ["data", "total", "limit", "offset"],
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserResponse" }
          },
          "total": { "type": "integer", "example": 42 },
          "limit": { "type": "integer", "example": 20 },
          "offset": { "type": "integer", "example": 0 }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "first_name": { "type": "string", "example": "Ravi" },
          "last_name": { "type": "string", "example": "Kumar" },
          "email": { "type": "string", "example": "ravi@example.com" },
          "dob": { "type": "string", "format": "date", "example": "1990-05-15" },
          "gender": { "$ref": "#/components/schemas/Gender" },
          "address": { "$ref": "#/components/schemas/AddressDetails" }
        }
      },
      "CompleteOnboardingRequest": {
        "type": "object",
        "required": ["first_name", "last_name", "dob", "gender", "address"],
        "properties": {
          "first_name": { "type": "string", "example": "Ravi" },
          "last_name": { "type": "string", "example": "Kumar" },
          "dob": { "type": "string", "format": "date", "example": "1990-05-15" },
          "gender": { "$ref": "#/components/schemas/Gender" },
          "address": { "$ref": "#/components/schemas/AddressDetails" },
          "email": { "type": "string", "example": "ravi@example.com" },
          "id_proof": { "$ref": "#/components/schemas/IdProof" }
        }
      },
      "CompleteOnboardingResponse": {
        "type": "object",
        "required": ["user", "access_token"],
        "properties": {
          "user": { "$ref": "#/components/schemas/UserResponse" },
          "access_token": { "type": "string", "description": "Fresh JWT with status=active." }
        }
      },
      "DeleteUserResponse": {
        "type": "object",
        "required": ["user_id", "deleted"],
        "properties": {
          "user_id": { "type": "string", "example": "usr_7Hq4nMdKpRsXwYzA1b" },
          "deleted": { "type": "boolean", "example": true }
        }
      }
    }
  }
}
