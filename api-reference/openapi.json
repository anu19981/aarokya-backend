  },
  "components": {
    "schemas": {
      "CreateWalletResponse": {
        "type": "object",
        "required": [
          "user_id",
          "transcorp_wallet_id",
          "balance",
          "wallet_status",
          "wallet_status_transcorp",
          "created"
        ],
        "properties": {
          "balance": {
            "type": "integer",
            "format": "int64",
            "description": "Balance in minor units (paise for INR)."
          },
          "created": {
            "type": "boolean",
            "description": "`true` if a new row was inserted; `false` if the wallet already existed."
          },
          "transcorp_wallet_id": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "wallet_status": {
            "$ref": "#/components/schemas/WalletStatus"
          },
          "wallet_status_transcorp": {
            "$ref": "#/components/schemas/WalletStatusTranscorp"
          }
        }
      },
      "GetUserProfileResponse": {
        "type": "object",
        "description": "Response body for GET /user/profile.",
        "required": [
          "user_id",
          "phone",
          "profile_complete"
        ],
        "properties": {
          "aadhaar_last4": {
            "type": [
              "string",
              "null"
            ],
            "description": "Aadhaar last-4 masked as \"XXXXXXXX{last4}\", e.g. \"XXXXXXXX1234\"."
          },
          "address": {
            "type": [
              "string",
              "null"
            ]
          },
          "dob": {
            "type": [
              "string",
              "null"
            ],
            "description": "Date of birth as \"YYYY-MM-DD\" string, if set."
          },
          "email": {
            "type": [
              "string",
              "null"
            ]
          },
          "employer": {
            "type": [
              "string",
              "null"
            ]
          },
          "first_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "gender": {
            "type": [
              "string",
              "null"
            ],
            "description": "One of: \"male\", \"female\", \"other\".",
            "example": "male"
          },
          "last_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "occupation": {
            "type": [
              "string",
              "null"
            ],
            "description": "One of: \"salaried\", \"self_employed\", \"professional\", \"student\", \"homemaker\", \"retired\", \"other\".",
            "example": "salaried"
          },
          "phone": {
            "type": "string"
          },
          "profile_complete": {
            "type": "boolean",
            "description": "`true` when both `first_name` and `last_name` are present."
          },
          "user_id": {
            "type": "string"
          }
        }
      },
      "GetWalletBalanceOutput": {
        "type": "object",
        "required": [
          "wallet_id",
          "current_balance",
          "currency"
        ],
        "properties": {
          "currency": {
            "type": "string"
          },
          "current_balance": {
            "type": "integer",
            "format": "int64"
          },
          "last_refreshed": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Timestamp"
              }
            ]
          },
          "linked": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "wallet_id": {
            "type": "string"
          }
        }
      },
      "GetWalletStatusOutput": {
        "type": "object",
        "required": [
          "wallet_id",
          "wallet_status"
        ],
        "properties": {
          "wallet_id": {
            "type": "string"
          },
          "wallet_status": {
            "$ref": "#/components/schemas/WalletStatus"
          }
        }
      },
      "GetWalletTransactionHistoryOutput": {
        "type": "object",
        "required": [
          "wallet_id",
          "transactions"
        ],
        "properties": {
          "transactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WalletTransaction"
            }
          },
          "wallet_id": {
            "type": "string"
          }
        }
      },
      "LogoutResponse": {
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "OtpTriggerRequest": {
        "type": "object",
        "required": [
          "phone"
        ],
        "properties": {
          "phone": {
            "type": "string"
          }
        }
      },
      "OtpTriggerResponse": {
        "type": "object",
        "required": [
          "success"
        ],
        "properties": {
          "otp": {
            "type": [
              "string",
              "null"
            ],
            "description": "In UAT: OTP returned for testing; remove in production"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "OtpVerifyRequest": {
        "type": "object",
        "required": [
          "phone",
          "otp"
        ],
        "properties": {
          "device_info": {
            "type": [
              "string",
              "null"
            ]
          },
          "otp": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "OtpVerifyResponse": {
        "type": "object",
        "required": [
          "success",
          "message",
          "user_id",
          "is_new_user",
          "access_token",
          "refresh_token",
          "access_token_expires_at",
          "refresh_token_expires_at"
        ],
        "properties": {
          "access_token": {
            "type": "string"
          },
          "access_token_expires_at": {
            "type": "integer",
            "format": "int64"
          },
          "is_new_user": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string"
          },
          "refresh_token_expires_at": {
            "type": "integer",
            "format": "int64"
          },
          "success": {
            "type": "boolean"
          },
          "user_id": {
            "type": "string"
          }
        }
      },
      "Timestamp": {
        "type": "object",
        "required": [
          "seconds"
        ],
        "properties": {
          "seconds": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "TokenRefreshRequest": {
        "type": "object",
        "required": [
          "refresh_token"
        ],
        "properties": {
          "refresh_token": {
            "type": "string"
          }
        }
      },
      "TokenRefreshResponse": {
        "type": "object",
        "required": [
          "success",
          "access_token",
          "refresh_token",
          "access_token_expires_at",
          "refresh_token_expires_at"
        ],
        "properties": {
          "access_token": {
            "type": "string"
          },
          "access_token_expires_at": {
            "type": "integer",
            "format": "int64"
          },
          "refresh_token": {
            "type": "string"
          },
          "refresh_token_expires_at": {
            "type": "integer",
            "format": "int64"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "TransactionStatus": {
        "type": "string",
        "enum": [
          "SUCCESS",
          "FAILED",
          "PENDING"
        ]
      },
      "UpdateUserProfileRequest": {
        "type": "object",
        "description": "Request body for PATCH /user/profile.\n\nAll fields are optional — only provided fields are updated.\n`dob` must be in \"YYYY-MM-DD\" format.\n`phone` and `aadhaar_last4` cannot be updated via this endpoint.",
        "properties": {
          "address": {
            "type": [
              "string",
              "null"
            ]
          },
          "dob": {
            "type": [
              "string",
              "null"
            ],
            "description": "Date of birth in \"YYYY-MM-DD\" format."
          },
          "email": {
            "type": [
              "string",
              "null"
            ]
          },
          "employer": {
            "type": [
              "string",
              "null"
            ]
          },
          "first_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "gender": {
            "type": [
              "string",
              "null"
            ],
            "description": "One of: \"male\", \"female\", \"other\".",
            "example": "male"
          },
          "last_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "occupation": {
            "type": [
              "string",
              "null"
            ],
            "description": "One of: \"salaried\", \"self_employed\", \"professional\", \"student\", \"homemaker\", \"retired\", \"other\".",
            "example": "salaried"
          }
        }
      },
      "UpdateUserProfileResponse": {
        "type": "object",
        "description": "Response body for PATCH /user/profile.",
        "required": [
          "user_id",
          "phone",
          "profile_complete"
        ],
        "properties": {
          "aadhaar_last4": {
            "type": [
              "string",
              "null"
            ],
            "description": "Aadhaar last-4 masked as \"XXXXXXXX{last4}\", e.g. \"XXXXXXXX1234\"."
          },
          "address": {
            "type": [
