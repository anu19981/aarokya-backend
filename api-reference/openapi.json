          "400": {
            "description": "Validation error — invalid gender or dob format"
          },
          "401": {
            "description": "Missing or invalid token"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
