    "/insurance/claims/{claimId}/status": {
      "get": {
        "tags": ["Insurance Claims"],
        "operationId": "get_claim_status",
        "security": [{"Bearer": []}],
        "parameters": [
          {
            "name": "claimId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
